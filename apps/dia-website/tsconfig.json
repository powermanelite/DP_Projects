{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@dia/shared": ["../dia-shared/src/index.ts"],
      "@dia/shared/*": ["../dia-shared/src/*"],
      "@dia/home": ["../dia-home/src/index.ts"],
      "@dia/calendar": ["../dia-calendar/src/index.ts"],
      "@dia/map": ["../dia-map/src/index.ts"]
    }
  },
  "include": ["src"],
}
